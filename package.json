{
  "name": "xskill",
  "private": true,
  "version": "0.5.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "RUSTUP_TOOLCHAIN=stable tauri",
    "test": "vitest run",
    "test:rust": "cd src-tauri && cargo test -- --test-threads=1",
    "test:all": "npm run test && npm run test:rust",
    "test:watch": "vitest",
    "session": "node .trae/skills/session-manager/scripts/session.js",
    "session:start": "node .trae/skills/session-manager/scripts/session.js start",
    "session:add": "node .trae/skills/session-manager/scripts/session.js add",
    "session:end": "node .trae/skills/session-manager/scripts/session.js end",
    "session:list": "node .trae/skills/session-manager/scripts/session.js list",
    "session:search": "node .trae/skills/session-manager/scripts/session.js search",
    "session:view": "node .trae/skills/session-manager/scripts/session.js view",
    "work": "node .trae/skills/work-flow/scripts/work.js"
  },
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cmk": "^0.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-virtualized-auto-sizer": "^1.0.25",
    "react-window": "^1.8.10",
    "tailwind-merge": "^3.5.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
